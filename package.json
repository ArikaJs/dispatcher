    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/arikajs/dispatcher.git"
    },
    "bugs": {
        "url": "https://github.com/arikajs/dispatcher/issues"
    },
    "homepage": "https://github.com/arikajs/dispatcher#readme",
    "dependencies": {
        "@arikajs/foundation": "file:../foundation",
        "@arikajs/http": "file:../http",
        "@arikajs/router": "file:../router"
    },
    "devDependencies": {
        "@types/node": "^20.11.24",
        "typescript": "^5.3.3"
    },
